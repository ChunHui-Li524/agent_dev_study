# ============================================
# Phase 3: LlamaIndex - 环境变量
# ============================================
# 本文件仅为示例，实际配置请使用项目根目录的 .env 文件

# Embeddings 配置
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 向量数据库配置
CHROMA_PERSIST_DIR=./data/chroma

# 索引配置
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# 查询配置
SIMILARITY_TOP_K=5
RESPONSE_MODE=compact
