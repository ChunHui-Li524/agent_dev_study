# ============================================
# Phase 5: CrewAI - 环境变量
# ============================================
# 本文件仅为示例，实际配置请使用项目根目录的 .env 文件

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# 模型配置
DEFAULT_MODEL=gpt-4o-mini
TEMPERATURE=0.7
MAX_TOKENS=2000

# CrewAI 配置
CREWAI_MAX_RPM=100
CREWAI_MAX_ITER=15

# 工具配置
SERPER_API_KEY=your_serper_api_key_here
