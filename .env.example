# ============================================
# AI Agent 学习工程 - 全局环境变量配置
# ============================================
# 使用说明：
# 1. 复制此文件为 .env（Windows: copy .env.example .env）
# 2. 在 .env 文件中填入你的实际 API 密钥
# 3. 不要将 .env 文件提交到 Git 仓库

# ============================================
# OpenAI 配置
# ============================================
# 获取 API Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# 如果需要使用代理，配置自定义 Base URL
# 例如: OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_BASE_URL=

# ============================================
# Anthropic Claude 配置
# ============================================
# 获取 API Key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# 智谱 AI (ChatGLM) 配置
# ============================================
# 获取 API Key: https://open.bigmodel.cn/usercenter/apikeys
ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# ============================================
# 阿里通义千问 配置
# ============================================
# 获取 API Key: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ============================================
# 百度文心一言 (Qianfan) 配置
# ============================================
# 获取 Access Key: https://cloud.baidu.com/doc/WENXINWORKSHOP/s/Ilkkrb0i5
QIANFAN_ACCESS_KEY=your_qianfan_access_key_here
QIANFAN_SECRET_KEY=your_qianfan_secret_key_here

# ============================================
# 其他配置选项
# ============================================
# 默认使用的 LLM 提供商（可选：openai, anthropic, zhipuai, dashscope, qianfan）
DEFAULT_LLM_PROVIDER=openai

# 请求超时时间（秒）
REQUEST_TIMEOUT=60

# 是否启用详细日志（true/false）
ENABLE_VERBOSE_LOGGING=false

# 最大重试次数
MAX_RETRIES=3
