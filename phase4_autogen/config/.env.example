# ============================================
# Phase 4: AutoGen - 环境变量
# ============================================
# 本文件仅为示例，实际配置请使用项目根目录的 .env 文件

# AutoGen 配置
AUTOGEN_MAX_CONSECUTIVE_AUTO_REPLY=10
AUTOGEN_CODE_EXECUTION_DIR=./code_output

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# 模型配置
DEFAULT_MODEL=gpt-4o-mini
TEMPERATURE=0.7
MAX_TOKENS=2000
